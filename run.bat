@echo off
chcp 65001 >nul
REM ============================================
REM  키움 자동매매 - 실행 스크립트 (자동 재시작)
REM  비정상 종료 시 10초 후 자동으로 재실행합니다.
REM ============================================
title 키움 자동매매

:restart
echo.
echo ========================================
echo   키움 자동매매를 시작합니다 (%date% %time%)
echo ========================================
echo.

python main.py %*

echo.
echo [경고] 프로그램이 종료되었습니다. (종료코드: %errorlevel%)
echo 10초 후 자동으로 재시작합니다. 중단하려면 이 창을 닫으세요.
timeout /t 10
goto restart
