# 키움증권 계좌 설정 (.env 파일로 복사 후 실제 값 입력)
KIWOOM_ACCOUNT=1234567890   # 실제 계좌번호
KIWOOM_SIMUL=True           # True: 모의투자, False: 실거래

# 매매 한도 (지표 전략 모드 기본값)
MAX_BUY_AMOUNT=1000000      # 1회 최대 매수금액 (원)
MAX_STOCK_COUNT=5           # 최대 동시 보유 종목수
STOP_LOSS_RATE=-0.05        # 손절 기준 (-5%)
TAKE_PROFIT_RATE=0.10       # 익절 기준 (+10%)

# 조건검색 모드 전용 한도 (미지정 시 위 기본값 사용)
COND_MAX_BUY_AMOUNT=500000  # 조건검색 1회 최대 매수금액
COND_MAX_STOCK_COUNT=10     # 조건검색 최대 동시 보유 종목수
COND_STOP_LOSS_RATE=-0.03   # 조건검색 손절 기준 (-3%)
COND_TAKE_PROFIT_RATE=0.05  # 조건검색 익절 기준 (+5%)

# 안전장치 (초보자 보호)
DAILY_LOSS_LIMIT_RATE=-0.10  # 일일 손실 한도 (-10% 도달 시 매수 자동중단)
MAX_ORDERS_PER_DAY=20        # 하루 최대 주문 횟수
MIN_AVAILABLE_CASH=10000     # 최소 주문가능액 (이하면 매수 차단)

# 매매 알림 (슬랙 / 텔레그램 - 사용하는 채널만 입력, 둘 다 비우면 비활성화)
SLACK_WEBHOOK_URL=          # https://hooks.slack.com/services/XXX/YYY/ZZZ
TELEGRAM_BOT_TOKEN=         # BotFather에서 발급받은 토큰
TELEGRAM_CHAT_ID=           # 알림 받을 채팅 ID

LOG_LEVEL=INFO
